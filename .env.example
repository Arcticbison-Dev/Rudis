# Altostratus Payments Configuration

# Session secret for authentication (required)
SESSION_SECRET=your-secret-key-here

# Webhook configuration
# URL to send payment notifications to the main Altostratus app
ALTOSTRATUS_WEBHOOK_URL=

# HMAC secret for signing webhooks (X-Altostratus-Signature header)
ALT_WEBHOOK_SECRET=your-webhook-secret-here

# Webhook timeout in milliseconds (default: 10000 = 10 seconds)
WEBHOOK_TIMEOUT_MS=10000

# Maximum webhook retry attempts before giving up (default: 10)
WEBHOOK_MAX_ATTEMPTS=10

# Maximum age of failed webhooks before auto-cleanup in hours (default: 24)
WEBHOOK_MAX_AGE_HOURS=24

# Webhook retry delays in milliseconds (exponential backoff)
WEBHOOK_RETRY_DELAY_1=1000
WEBHOOK_RETRY_DELAY_2=3000
WEBHOOK_RETRY_DELAY_3=9000

# Invoice expiration settings
# Hours before expiration to show "expiring soon" warning (default: 1 hour)
VITE_EXPIRING_SOON_HOURS=1

# Cleanup job settings
# Days to keep expired invoices before purging (30-90 range enforced, default: 90)
CLEANUP_EXPIRED_DAYS=90
