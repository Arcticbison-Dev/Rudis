# Altostratus Payments Configuration

# Session secret for authentication (required)
SESSION_SECRET=your-secret-key-here

# Webhook configuration
# URL to send payment notifications to the main Altostratus app
ALTOSTRATUS_WEBHOOK_URL=

# HMAC secret for signing webhooks (X-Altostratus-Signature header)
ALT_WEBHOOK_SECRET=your-webhook-secret-here

# Webhook timeout in milliseconds (default: 10000 = 10 seconds)
WEBHOOK_TIMEOUT_MS=10000

# Maximum webhook retry attempts before giving up (default: 10)
WEBHOOK_MAX_ATTEMPTS=10

# Maximum age of failed webhooks before auto-cleanup in hours (default: 24)
WEBHOOK_MAX_AGE_HOURS=24

# Webhook retry delays in milliseconds (exponential backoff)
WEBHOOK_RETRY_DELAY_1=1000
WEBHOOK_RETRY_DELAY_2=3000
WEBHOOK_RETRY_DELAY_3=9000

# Invoice expiration settings
# Hours before expiration to show "expiring soon" warning (default: 1 hour)
VITE_EXPIRING_SOON_HOURS=1

# Cleanup job settings
# Days to keep expired invoices before purging (30-90 range enforced, default: 90)
CLEANUP_EXPIRED_DAYS=90

# Data retention and privacy settings
# Days to keep paid invoices before anonymization (default: 90)
RETENTION_PAID_DAYS=90

# Days to keep all invoices before permanent deletion (default: 365)
RETENTION_MAX_DAYS=365

# Enable automatic anonymization of old invoices (default: true)
AUTO_ANONYMIZE_ENABLED=true

# ==========================================
# RAIL SERVICE AUTHENTICATION
# ==========================================

# Shared secret for rail services to authenticate callbacks (REQUIRED if rails enabled)
# Generate with: openssl rand -hex 32
RAIL_AUTH_TOKEN=

# ==========================================
# RAIL SERVICE URLs (for production blockchain listeners)
# ==========================================

# Lightning Network rail service URL (default: http://localhost:5001)
LN_SERVICE_URL=http://localhost:5001

# Bitcoin on-chain rail service URL (default: http://localhost:5002)
BTC_SERVICE_URL=http://localhost:5002

# Monero rail service URL (default: http://localhost:5003)
XMR_SERVICE_URL=http://localhost:5003

# ==========================================
# FEATURE FLAGS (Enable real blockchain payment rails)
# ==========================================

# Enable Lightning Network payments (default: false)
ENABLE_LN=false

# Enable Bitcoin on-chain payments (default: false)
ENABLE_BTC=false

# Enable Monero payments (default: false)
ENABLE_XMR=false

# ==========================================
# SIMULATION (TESTING ONLY - DISABLE IN PRODUCTION)
# ==========================================

# Enable payment simulation endpoint (default: false, MUST be false in production)
# WARNING: Only enable in development/staging environments
SIMULATION_ENABLED=false

# Admin token for simulation endpoint (REQUIRED if SIMULATION_ENABLED=true)
# Generate with: openssl rand -hex 32
ADMIN_SIM_TOKEN=

# ==========================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ==========================================
# Before deploying to production:
# ✓ Set strong random values for ALT_WEBHOOK_SECRET, RAIL_AUTH_TOKEN, ADMIN_SIM_TOKEN
# ✓ Set SIMULATION_ENABLED=false
# ✓ Configure rail service URLs to point to production endpoints
# ✓ Enable only the payment rails you've deployed (ENABLE_LN, ENABLE_BTC, ENABLE_XMR)
# ✓ Set ALTOSTRATUS_WEBHOOK_URL to your production Altostratus app URL
# ✓ Review all timeout and retry settings for your infrastructure
