# =============================================================================
# Altostratus Payments - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in required values.
# Run ./setup.sh to auto-generate secrets and validate configuration.
# =============================================================================

# --- Database (REQUIRED) ---
DATABASE_URL=postgresql://user:password@localhost:5432/altostratus_payments

# --- Security Tokens (REQUIRED - generate with: openssl rand -hex 32) ---
ADMIN_API_TOKEN=
RAIL_AUTH_TOKEN=
SESSION_SECRET=
ALT_WEBHOOK_SECRET=

# --- Payment Rails (enable at least one) ---
ENABLE_LN=false
ENABLE_BTC=false
ENABLE_XMR=false

# --- Lightning Network (required if ENABLE_LN=true) ---
LNBITS_API_KEY=
LNBITS_WALLET_KEY=
LNBITS_API_URL=
LNBITS_WALLET_ID=
LNBITS_WEBHOOK_SECRET=
LNBITS_WEBHOOK_URL=
LN_BACKEND=lnbits
LN_INVOICE_EXPIRY=3600
LN_MIN_AMOUNT_SATS=1
LN_MAX_AMOUNT_SATS=100000
LN_POLL_INTERVAL_MS=10000
LN_HTTP_TIMEOUT=5000
LN_DEBUG_LOGGING=false
LN_LOG_API_BODIES=false

# --- Bitcoin On-Chain (required if ENABLE_BTC=true) ---
BTC_XPUB=
BTC_NETWORK=testnet
BTC_SERVICE_URL=http://localhost:5002
BTC_CONFIRMATIONS_REQUIRED=3
MEMPOOL_API_BASE=https://mempool.space/api

# --- Monero (required if ENABLE_XMR=true) ---
XMR_SERVICE_URL=http://localhost:5003
XMR_RPC_HOST=127.0.0.1
XMR_RPC_PORT=18083
XMR_RPC_USERNAME=
XMR_RPC_PASSWORD=
XMR_NETWORK=stagenet
XMR_CONFIRMATIONS_REQUIRED=10
XMR_ACCOUNT_INDEX=0
XMR_DEV_MODE=false

# --- Webhook Notifications ---
ALTOSTRATUS_WEBHOOK_URL=
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_ATTEMPTS=10
WEBHOOK_MAX_AGE_HOURS=24
WEBHOOK_RETRY_DELAY_1=1000
WEBHOOK_RETRY_DELAY_2=3000
WEBHOOK_RETRY_DELAY_3=9000

# --- Data Retention & Privacy ---
RETENTION_PAID_DAYS=90
RETENTION_MAX_DAYS=365
CLEANUP_EXPIRED_DAYS=90
AUTO_ANONYMIZE_ENABLED=true

# --- Simulation / Development (DISABLE IN PRODUCTION) ---
SIMULATION_ENABLED=false
ADMIN_SIM_TOKEN=

# --- Optional Invoice API Key ---
# When set, POST /api/invoices requires Authorization: Bearer <key>
# When not set, the endpoint remains public (rate-limited only)
INVOICE_API_KEY=

# --- Server ---
PORT=5000
