# Altostratus Payments Configuration

# Session secret for authentication (required)
SESSION_SECRET=your-secret-key-here

# Webhook configuration
# URL to send payment notifications to the main Altostratus app
ALTOSTRATUS_WEBHOOK_URL=

# HMAC secret for signing webhooks (X-Altostratus-Signature header)
ALT_WEBHOOK_SECRET=your-webhook-secret-here

# Webhook timeout in milliseconds (default: 10000 = 10 seconds)
WEBHOOK_TIMEOUT_MS=10000

# Maximum webhook retry attempts before giving up (default: 10)
WEBHOOK_MAX_ATTEMPTS=10

# Maximum age of failed webhooks before auto-cleanup in hours (default: 24)
WEBHOOK_MAX_AGE_HOURS=24

# Webhook retry delays in milliseconds (exponential backoff)
WEBHOOK_RETRY_DELAY_1=1000
WEBHOOK_RETRY_DELAY_2=3000
WEBHOOK_RETRY_DELAY_3=9000

# Invoice expiration settings
# Hours before expiration to show "expiring soon" warning (default: 1 hour)
VITE_EXPIRING_SOON_HOURS=1

# Cleanup job settings
# Days to keep expired invoices before purging (30-90 range enforced, default: 90)
CLEANUP_EXPIRED_DAYS=90

# Data retention and privacy settings
# Days to keep paid invoices before anonymization (default: 90)
RETENTION_PAID_DAYS=90

# Days to keep all invoices before permanent deletion (default: 365)
RETENTION_MAX_DAYS=365

# Enable automatic anonymization of old invoices (default: true)
AUTO_ANONYMIZE_ENABLED=true

# ==========================================
# RAIL SERVICE AUTHENTICATION
# ==========================================

# Shared secret for rail services to authenticate callbacks (REQUIRED if rails enabled)
# Generate with: openssl rand -hex 32
RAIL_AUTH_TOKEN=

# Admin API authentication token (Step 5.3: Security for admin endpoints)
# Used for admin endpoints like GET /admin/invoices
# Generate a secure random token: openssl rand -hex 32
ADMIN_API_TOKEN=

# ==========================================
# RAIL SERVICE URLs (for production blockchain listeners)
# ==========================================

# Bitcoin on-chain rail service URL (default: http://localhost:5002)
BTC_SERVICE_URL=http://localhost:5002

# Monero rail service URL (default: http://localhost:5003)
XMR_SERVICE_URL=http://localhost:5003

# ==========================================
# LIGHTNING NETWORK CONFIGURATION (LNbits + LND)
# ==========================================
# Architecture: Payment App → LNbits API → LND Backend
#
# Your app communicates with LNbits API (LNBITS_* variables).
# LNbits communicates with LND backend (LND_* variables - NOT used by your app).
#
# INSTANT SETTLEMENT DESIGN:
# Lightning invoices are confirmed as soon as LNbits reports them as paid.
# No confirmation waiting period - instant settlement by design.
# The only timing controls:
#   - Poll interval (if using polling mode)
#   - Webhook delivery (if using webhook mode)
#   - Invoice expiry time (handled by LNbits/LND)

# ──────────────────────────────────────────
# 1️⃣ LN RAIL CONTROLS (Feature Flags & Behavior)
# ──────────────────────────────────────────

# Enable Lightning Network payment rail (default: false)
# Set to true to activate Lightning Network invoices via LNbits
# When enabled, LNBITS_API_URL and LNBITS_WALLET_KEY must be configured
# Also defined in Feature Flags section below for consistency with other rails
ENABLE_LN=false

# Lightning backend type (currently only 'lnbits' supported)
# Future: may support 'lnd', 'cln', 'eclair' for direct integration
LN_BACKEND=lnbits

# HTTP timeout for LNbits API calls in milliseconds (default: 5000 = 5 seconds)
LN_HTTP_TIMEOUT=5000

# Lightning invoice expiration in seconds (default: 3600 = 1 hour)
# LNbits invoices auto-expire after this duration
LN_INVOICE_EXPIRY=3600

# Minimum invoice amount in satoshis (default: 1 sat)
# Prevents dust invoices that cost more in fees than they're worth
# Requests below this amount will be rejected with validation error (400)
# Note: Lightning-specific limits, independent of BTC/XMR validation
LN_MIN_AMOUNT_SATS=1

# Maximum invoice amount in satoshis (default: 100000 = 0.001 BTC)
# Conservative limit to prevent large exposure before settlement
# Requests above this amount will be rejected with business rule error (400)
# Note: Lightning-specific limits, independent of BTC/XMR validation
LN_MAX_AMOUNT_SATS=100000

# Poll interval for checking unpaid invoices in milliseconds (default: 10000 = 10 seconds)
# How often to check LNbits for invoice payment status
# Behavior depends on webhook configuration:
#   - If webhooks configured: Light polling as safety net (catches missed webhooks)
#   - If webhooks NOT configured: Primary payment detection mechanism
LN_POLL_INTERVAL_MS=10000

# ──────────────────────────────────────────
# 2️⃣ LNBITS API CONFIGURATION (Your App → LNbits)
# ──────────────────────────────────────────

# LNbits server base URL (without trailing slash or /api/v1)
# Examples:
#   Hosted: https://legend.lnbits.com
#   Self-hosted: https://lnbits.yourdomain.com
#   Local dev: http://localhost:5000
LNBITS_API_URL=

# LNbits wallet key for creating and checking invoices
# Key type: Use "Invoice/Read" key (NOT "Admin" key)
# Generate: LNbits → Wallet → API Info → Copy "Invoice/Read key"
# SECURITY: Store in Replit Secrets, never commit to git
# Permission: Can create invoices and read wallet (cannot spend)
LNBITS_WALLET_KEY=

# Optional: LNbits wallet ID (leave empty to use key's default wallet)
# Only needed if managing multiple wallets with different keys
LNBITS_WALLET_ID=

# ──────────────────────────────────────────
# 3️⃣ LND BACKEND CONFIG (LNbits → LND) - NOT USED BY YOUR APP
# ──────────────────────────────────────────
# These variables configure LNbits' connection to its LND backend.
# Your payment app NEVER uses these directly - only LNbits does.
# Only set these if you're managing the LNbits instance yourself.
# If using hosted LNbits (e.g., legend.lnbits.com), these are NOT needed.

# LND gRPC host (used by LNbits, not your app)
# Examples:
#   Local: localhost:10009
#   Remote: lnd.yourdomain.com:10009
LND_GRPC_HOST=

# LND TLS certificate (base64-encoded, used by LNbits, not your app)
# Generate: cat ~/.lnd/tls.cert | base64 -w 0
# Leave empty if LNbits is already configured with LND
LND_TLS_CERT_BASE64=

# LND invoice macaroon (hex-encoded, used by LNbits, not your app)
# Generate: xxd -ps -u -c 1000 ~/.lnd/data/chain/bitcoin/mainnet/invoice.macaroon
# Permissions: invoice.read, invoice.write (sufficient for receiving)
LND_INVOICE_MACAROON=

# LND network (mainnet, testnet, regtest)
# Used by LNbits to determine correct network context
LND_NETWORK=mainnet

# IMPORTANT: LND credentials should ONLY be used by LNbits, not your payment app.
# These are included for documentation purposes if you're self-hosting LNbits.

# ──────────────────────────────────────────
# 4️⃣ WEBHOOK CONFIGURATION (LNbits → Your App) - RECOMMENDED
# ──────────────────────────────────────────
# LNbits can push instant payment notifications instead of polling.
# Recommended for production to reduce API calls and improve responsiveness.
#
# Webhook Strategy & Interaction with Polling:
#   If webhooks configured:
#     - Primary: LNbits POSTs to LNBITS_WEBHOOK_URL when invoice paid
#     - Fallback: Light polling every LN_POLL_INTERVAL_MS (safety net)
#     - Retry: No webhook retry in app (LNbits handles webhook retries)
#     - Result: Instant notifications with polling backup
#   
#   If webhooks NOT configured:
#     - Primary: Polling every LN_POLL_INTERVAL_MS (only detection method)
#     - Fallback: None
#     - Result: Payment detection delayed by up to LN_POLL_INTERVAL_MS

# Webhook URL where LNbits sends payment notifications
# Your app will receive POST requests here when invoices are paid
# Format: https://your-replit-app.repl.co/webhooks/lnbits
# Leave empty to use polling-only mode (not recommended for production)
LNBITS_WEBHOOK_URL=

# Webhook secret for verifying LNbits webhook authenticity
# Generate with: openssl rand -hex 32
# LNbits includes this in webhook signature headers
# SECURITY: Store in Replit Secrets, verify all incoming webhooks
LNBITS_WEBHOOK_SECRET=

# Webhook timeout in milliseconds (default: 5000 = 5 seconds)
# How long to wait for LNbits webhook delivery before timeout
LNBITS_WEBHOOK_TIMEOUT_MS=5000

# ──────────────────────────────────────────
# 5️⃣ LOGGING & DEBUG CONTROLS
# ──────────────────────────────────────────

# Enable verbose Lightning Network debug logging (default: false)
# WARNING: May log sensitive data in development mode - MUST be false in production
# Logs: API requests/responses, webhook payloads, polling cycles
LN_DEBUG_LOGGING=false

# Log LNbits API request/response bodies (default: false)
# Useful for debugging integration issues
# WARNING: MUST be false in production (may contain payment details)
LN_LOG_API_BODIES=false

# ==========================================
# SECURITY CHECKLIST FOR LIGHTNING NETWORK
# ==========================================
# Before enabling ENABLE_LN=true:
# ✓ Set LNBITS_WALLET_KEY in Replit Secrets (use Invoice/Read key, NOT Admin key)
# ✓ Set LNBITS_WEBHOOK_SECRET in Replit Secrets (if using webhooks)
# ✓ Verify LNBITS_API_URL is accessible and LNbits server is healthy
# ✓ Set LN_DEBUG_LOGGING=false in production
# ✓ Set LN_LOG_API_BODIES=false in production
# ✓ Configure sensible min/max amounts (LN_MIN_AMOUNT_SATS, LN_MAX_AMOUNT_SATS)
# ✓ Test invoice creation and payment on testnet first
# ✓ Verify webhook signature validation (if using webhooks)
# ✓ Never commit LND credentials to git (only LNbits uses them, not your app)
# ✓ All LN secrets stored in Replit Secrets, not in code or .env files

# ==========================================
# FEATURE FLAGS (Enable real blockchain payment rails)
# ==========================================

# NOTE: ENABLE_LN is defined in the Lightning Network Configuration section above
# for better organization. It is repeated here for quick reference alongside other rails.

# Enable Lightning Network payments (default: false)
# Primary definition: See Lightning Network Configuration section
# ENABLE_LN=false

# Enable Bitcoin on-chain payments (default: false)
ENABLE_BTC=false

# Enable Monero payments (default: false)
ENABLE_XMR=false

# ==========================================
# SIMULATION (TESTING ONLY - DISABLE IN PRODUCTION)
# ==========================================

# Enable payment simulation endpoint (default: false, MUST be false in production)
# WARNING: Only enable in development/staging environments
SIMULATION_ENABLED=false

# Admin token for simulation endpoint (REQUIRED if SIMULATION_ENABLED=true)
# Generate with: openssl rand -hex 32
ADMIN_SIM_TOKEN=

# ==========================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ==========================================
# Before deploying to production:
# ✓ Set strong random values for ALT_WEBHOOK_SECRET, RAIL_AUTH_TOKEN, ADMIN_SIM_TOKEN
# ✓ Set SIMULATION_ENABLED=false
# ✓ Configure rail service URLs to point to production endpoints
# ✓ Enable only the payment rails you've deployed (ENABLE_LN, ENABLE_BTC, ENABLE_XMR)
# ✓ Set ALTOSTRATUS_WEBHOOK_URL to your production Altostratus app URL
# ✓ Review all timeout and retry settings for your infrastructure
