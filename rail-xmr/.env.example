# Monero Rail Service Configuration

# Port to run this service on
PORT=5003

# Payments service base URL (where to send callbacks)
ALT_PAYMENTS_BASE=http://localhost:5000

# Shared secret for authenticating callbacks to payments service
RAIL_AUTH_TOKEN=your-secure-token-here

# Future: Real Monero wallet RPC configuration
# XMR_WALLET_RPC_URL=http://localhost:18082/json_rpc
# XMR_WALLET_RPC_USER=username
# XMR_WALLET_RPC_PASS=password
# XMR_CONFIRMATIONS_REQUIRED=10
