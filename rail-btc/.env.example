# Bitcoin Rail Service Configuration

# Network: mainnet or testnet
BTC_NETWORK=testnet

# Extended public key (xpub for mainnet, tpub/vpub for testnet)
# BIP84 recommended for native segwit addresses (bc1... or tb1...)
# Generate from your HD wallet at derivation path m/84'/0'/0' (mainnet) or m/84'/1'/0' (testnet)
BTC_XPUB=tpubDDCYy...your-testnet-xpub-here

# Number of confirmations required before marking payment as confirmed
# Recommended: 6 for mainnet, 2-3 for testnet
BTC_CONFIRMATIONS_REQUIRED=2

# Authentication token (must match RAIL_AUTH_TOKEN in payments service)
RAIL_AUTH_TOKEN=your-64-char-hex-token-here

# Payments service URL
PAYMENTS_SERVICE_URL=http://localhost:5000

# Mempool API base URL (optional, auto-detected from BTC_NETWORK)
# MEMPOOL_API_BASE=https://mempool.space/testnet/api

# Blockchain polling interval in milliseconds (default: 30000 = 30 seconds)
# Lower values = faster payment detection, higher API usage
POLLING_INTERVAL_MS=30000

# Service port
PORT=5002
