# Bitcoin Rail Service Configuration

# Port to run this service on
PORT=5002

# Payments service base URL (where to send callbacks)
ALT_PAYMENTS_BASE=http://localhost:5000

# Shared secret for authenticating callbacks to payments service
RAIL_AUTH_TOKEN=your-secure-token-here

# Future: Real Bitcoin node configuration
# BTC_XPUB=xpub...your-extended-public-key
# CONFIRMATIONS_REQUIRED=6
# ELECTRUM_ENDPOINT=ssl://electrum.blockstream.info:50002
